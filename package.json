{
  "name": "coding-agent-v2",
  "version": "1.0.0",
  "description": "Coding Agent V2 - AI Coding Assistant",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "agent": "tsx examples/agent.ts",
    "example:agent:ui": "tsx examples/agent-ui/index.ts",
    "example:agent:v4:app": "tsx examples/agent-v4-app-demo.ts",
    "example:providers": "tsx src/agent-v2/agent.ts",
    "example:providers:manual": "tsx examples/providers-usage/manual-provider.ts",
    "test": "vitest",
    "test:run": "pnpm test:run:agent:v4 && pnpm --dir opentui-agent-cli test:run",
    "test:coverage": "vitest run --coverage",
    "lint": "pnpm lint:agent:v4 && pnpm --dir opentui-agent-cli lint",
    "lint:fix": "eslint src --ext .ts,.tsx --fix",
    "format": "prettier --write \"src/**/*.ts\" \"examples/**/*.ts\" \"*.json\"",
    "format:check": "pnpm format:check:agent:v4 && pnpm --dir opentui-agent-cli format:check",
    "format:fix": "prettier --write \"src/**/*.ts\" \"examples/**/*.ts\" --end-of-line lf",
    "typecheck": "pnpm typecheck:agent:v4 && pnpm --dir opentui-agent-cli exec tsc --noEmit -p tsconfig.check.json",
    "typecheck:agent:v4": "tsc --noEmit -p tsconfig.agent-v4.json",
    "format:check:agent:v4": "prettier --check \"src/agent-v4/**/*.ts\"",
    "lint:agent:v4": "eslint src/agent-v4 --ext .ts",
    "test:run:agent:v4": "vitest run src/agent-v4",
    "ci:check": "pnpm format:check && pnpm typecheck && pnpm lint && pnpm test:run",
    "prepare": "husky install"
  },
  "keywords": [
    "ai",
    "coding",
    "agent"
  ],
  "author": "",
  "license": "MIT",
  "devDependencies": {
    "@types/diff": "^8.0.0",
    "@types/node": "^20.10.0",
    "@types/shell-quote": "^1.7.5",
    "@types/strip-ansi": "^5.2.1",
    "@typescript-eslint/eslint-plugin": "^6.15.0",
    "@typescript-eslint/parser": "^6.15.0",
    "@vitest/coverage-v8": "^1.1.0",
    "cross-env": "^7.0.3",
    "eslint": "^8.56.0",
    "husky": "^8.0.3",
    "lint-staged": "^16.3.2",
    "prettier": "^3.1.1",
    "tsx": "^4.7.0",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "dependencies": {
    "@vscode/ripgrep": "^1.17.0",
    "diff": "^8.0.3",
    "dotenv": "^17.3.1",
    "js-tiktoken": "^1.0.21",
    "log-update": "^6.1.0",
    "marked": "^15.0.12",
    "marked-terminal": "^7.3.0",
    "minimatch": "^10.2.4",
    "shell-quote": "^1.8.3",
    "strip-ansi": "^7.2.0",
    "uuid": "^13.0.0",
    "zod": "^4.3.6"
  }
}
