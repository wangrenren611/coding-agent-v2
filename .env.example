
# =============================================================================
# Provider
# =============================================================================
GLM_API_KEY=

# =============================================================================
# Runtime Storage
# =============================================================================
# file | sqlite
AGENT_STORAGE_BACKEND=file

# File storage root dir (when backend=file)
AGENT_STORAGE_DIR=./data/agent-memory

# SQLite file path (when backend=sqlite)
# AGENT_SQLITE_PATH=./data/agent-memory/agent-memory.db

# =============================================================================
# Runtime Logger
# =============================================================================
# TRACE | DEBUG | INFO | WARN | ERROR | FATAL
AGENT_LOG_LEVEL=INFO

# true | false
AGENT_LOG_CONSOLE=true
AGENT_LOG_FILE_ENABLED=true

# Log file location (used when AGENT_LOG_FILE_ENABLED=true)
AGENT_LOG_DIR=./logs
AGENT_LOG_FILE=agent.log

# pretty | json
AGENT_LOG_FORMAT=pretty

# =============================================================================
# Agent Loop Limits (example runner)
# =============================================================================
# Positive integer, used by examples/agent-usage/index.ts
AGENT_MAX_STEPS=24
