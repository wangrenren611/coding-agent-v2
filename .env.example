# Coding Agent V2 - Environment Configuration Example
# Copy this file to .env and fill in your values

# ===========================================
# AI Model Configuration
# ===========================================

# Default AI model to use
AGENT_MODEL=gpt-4

# Maximum steps per agent run
AGENT_MAX_STEPS=1000

# Maximum retry count for failed operations
AGENT_MAX_RETRY_COUNT=3

# Tool confirmation mode: manual, auto-approve, or auto-deny
AGENT_TOOL_CONFIRMATION_MODE=manual

# Fixed conversation ID for CLI runtime
# AGENT_CONVERSATION_ID=

# Fallback session ID when AGENT_CONVERSATION_ID is unset
# AGENT_SESSION_ID=

# ===========================================
# API Keys (for different AI providers)
# ===========================================

# OpenAI
# OPENAI_API_KEY=your_openai_api_key_here

# Anthropic
# ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Google AI
# GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Azure OpenAI
# AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
# AZURE_OPENAI_ENDPOINT=your_azure_endpoint_here

# Cohere
# COHERE_API_KEY=your_cohere_api_key_here

# Hugging Face
# HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ===========================================
# Logging Configuration
# ===========================================

# Log level: TRACE, DEBUG, INFO, WARN, ERROR, FATAL
AGENT_LOG_LEVEL=INFO

# Log format: pretty or json
AGENT_LOG_FORMAT=pretty

# Enable/disable console logging
AGENT_LOG_CONSOLE=true

# Enable/disable file logging
AGENT_LOG_FILE_ENABLED=false

# ===========================================
# File History Configuration
# ===========================================

# Enable/disable file history tracking
AGENT_FILE_HISTORY_ENABLED=true

# Maximum history entries per file
AGENT_FILE_HISTORY_MAX_PER_FILE=20

# Maximum age of history entries in days
AGENT_FILE_HISTORY_MAX_AGE_DAYS=14

# Maximum total size of history in MB
AGENT_FILE_HISTORY_MAX_TOTAL_MB=500

# ===========================================
# Runtime Configuration
# ===========================================

# Home directory for Renx configuration
# RENX_HOME=~/.renx

# Force wcwidth for CJK character width handling
OPENTUI_FORCE_WCWIDTH=1

# ===========================================
# Development Configuration
# ===========================================

# Enable development mode
# NODE_ENV=development

# Enable debug mode
# DEBUG=coding-agent:*

# ===========================================
# Proxy Configuration (if needed)
# ===========================================

# HTTP proxy
# HTTP_PROXY=http://proxy.example.com:8080

# HTTPS proxy
# HTTPS_PROXY=http://proxy.example.com:8080

# No proxy hosts
# NO_PROXY=localhost,127.0.0.1

# ===========================================
# Performance Configuration
# ===========================================

# Node.js memory limit (in MB)
# NODE_OPTIONS=--max-old-space-size=4096

# Enable garbage collection logging
# NODE_DEBUG=gc

# ===========================================
# Security Configuration
# ===========================================

# Disable SSL verification (not recommended for production)
# NODE_TLS_REJECT_UNAUTHORIZED=0

# ===========================================
# Feature Flags
# ===========================================

# Enable experimental features
# AGENT_EXPERIMENTAL_FEATURES=false

# Enable beta features
# AGENT_BETA_FEATURES=false

# ===========================================
# Integration Configuration
# ===========================================

# GitHub integration
# GITHUB_TOKEN=your_github_token_here

# GitLab integration
# GITLAB_TOKEN=your_gitlab_token_here

# Bitbucket integration
# BITBUCKET_TOKEN=your_bitbucket_token_here

# ===========================================
# Custom Configuration
# ===========================================

# Add your custom environment variables below
# CUSTOM_VAR=value