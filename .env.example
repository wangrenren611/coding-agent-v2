
# =============================================================================
# Provider
# =============================================================================
GLM_API_KEY=
AGENT_LOG_FILE_ENABLED=true
AGENT_LOG_DIR=./logs
AGENT_LOG_FILE=agent-v4.log
AGENT_LOG_LEVEL=INFO
AGENT_LOG_FORMAT=json
AGENT_LOG_CONSOLE=false

# =============================================================================
# File Storage
# =============================================================================
# Unified root directory for agent temporary caches and file history snapshots.
AGENT_STORAGE_ROOT=.agent-storage

# Directory for write_file / write-buffer temporary session files.
AGENT_WRITE_BUFFER_DIR=.agent-storage/cache/write-buffer

# Directory for persisted old file versions used for restore.
AGENT_FILE_HISTORY_DIR=.agent-storage/history/file-versions

# Enable or disable snapshotting the previous file content before overwrite.
AGENT_FILE_HISTORY_ENABLED=true

# Maximum number of historical versions kept for the same file.
AGENT_FILE_HISTORY_MAX_PER_FILE=20

# Maximum retention window in days for file history snapshots.
AGENT_FILE_HISTORY_MAX_AGE_DAYS=14

# Maximum total size in MB allowed for all file history snapshots.
AGENT_FILE_HISTORY_MAX_TOTAL_MB=500
